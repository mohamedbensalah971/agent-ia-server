# ======================================
# AGENT IA SERVER - ENVIRONMENT VARIABLES
# ======================================
# 
# Instructions:
# 1. Copy this file to .env
# 2. Fill in your actual values
# 3. NEVER commit .env to Git!
#

# ===== GROQ API =====
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Model to use (default: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Max tokens per request
GROQ_MAX_TOKENS=4000

# Temperature (0.0 = deterministic, 1.0 = creative)
GROQ_TEMPERATURE=0.1

# ===== RATE LIMITING (Groq Free Tier) =====
RATE_LIMIT_TOKENS_PER_MINUTE=6000
RATE_LIMIT_TOKENS_PER_DAY=14400

# ===== GIT CONFIGURATION =====
# Path to your SmartTalk-Android project
GIT_REPO_PATH=C:/Users/Stayha/Desktop/pfe/SmartTalk-Android

# Branch prefix for AI corrections
GIT_BRANCH_PREFIX=fix/ai-correction

# Git author info
GIT_AUTHOR_NAME=AI Agent
GIT_AUTHOR_EMAIL=ai-agent@smarttalk.com

# ===== JENKINS (Optional - Phase 3) =====
JENKINS_URL=
JENKINS_USERNAME=
JENKINS_TOKEN=

# ===== SERVER CONFIGURATION =====
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ===== CACHE =====
CACHE_ENABLED=true
CACHE_TTL=3600

# ===== LOGGING =====
LOG_LEVEL=INFO
LOG_FILE=logs/agent_ia.log

# ===== RAG (Phase 2 - Leave empty for now) =====
RAG_ENABLED=false
RAG_ENDPOINT=
